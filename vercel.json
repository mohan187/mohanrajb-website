{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/marketing-site/pages/index.html" },
    { "source": "/resume", "destination": "/marketing-site/pages/resume.html" },
    { "source": "/portfolio", "destination": "/marketing-site/pages/portfolio.html" },
    { "source": "/blog", "destination": "/marketing-site/pages/blog.html" },
    { "source": "/contact", "destination": "/marketing-site/pages/contact.html" },
    { "source": "/styles/:path*", "destination": "/marketing-site/styles/:path*" },
    { "source": "/scripts/:path*", "destination": "/marketing-site/scripts/:path*" },
    { "source": "/assets/:path*", "destination": "/marketing-site/assets/:path*" }
  ]
}